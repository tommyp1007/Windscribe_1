// Configuration settings file format documentation can be found at:
// https://help.apple.com/xcode/#/dev745c5c974
APP_TEAM_ID = GYZJYS7XUG
APP_BUNDLE_ID = com.windscribe
PACKET_TUNNEL_EXT_BUNDLE_ID = $(APP_BUNDLE_ID).PacketTunnel
WIREGUARD_EXT_BUNDLE_ID = $(APP_BUNDLE_ID).WireGuardTunnel
SIRI_EXT_BUNDLE_ID = $(APP_BUNDLE_ID).SiriIntents
HOME_WIDGET_BUNDLE_ID = $(APP_BUNDLE_ID).HomeWidget
TEST_TARGET_BUNDLE_ID = com.WindscribeTests

// Single source of truth for app + extension versions (iOS).
// CI overrides CURRENT_PROJECT_VERSION via xcargs (CI_PIPELINE_IID); the value
// below is the local-build default. tvOS uses TV_MARKETING_VERSION on its own target.
MARKETING_VERSION = 3.12.0
CURRENT_PROJECT_VERSION = 1
TV_MARKETING_VERSION = 1.0.4
